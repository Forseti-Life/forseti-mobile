# Production environment variables
ENV=production

# API Configuration
API_BASE_URL=https://api.forseti.life/api
API_TIMEOUT=20000

# Feature Flags
ENABLE_DEBUG_MODE=false
ENABLE_MOCK_DATA=false
ENABLE_ANALYTICS=true

# Map Configuration
GOOGLE_MAPS_API_KEY=your_production_google_maps_api_key_here
DEFAULT_LATITUDE=37.7749
DEFAULT_LONGITUDE=-122.4194

# Auth Configuration
AUTH_DOMAIN=auth.forseti.life
AUTH_CLIENT_ID=production_client_id

# Other Settings
LOG_LEVEL=error

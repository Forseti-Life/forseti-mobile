{
  "name": "forseti-mobile",
  "version": "1.0.3",
  "description": "Forseti Mobile - AI-Powered Safety Monitoring for Philadelphia",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "react-native run-android --mode=debug",
    "android:release": "react-native run-android --mode=release",
    "android:build": "./increment-build.sh && cd android && ./gradlew assembleRelease && cd .. && ./scripts/copy-apk.sh release",
    "android:build:debug": "./increment-build.sh && cd android && ./gradlew assembleDebug && ../scripts/copy-apk.sh debug",
    "android:build:release": "./increment-build.sh && cd android && ./gradlew assembleRelease && ../scripts/copy-apk.sh release",
    "android:clean": "cd android && ./gradlew clean",
    "android:bundle": "./increment-build.sh && cd android && ./gradlew bundleRelease",
    "android:deploy": "./build-and-deploy.sh",
    "version:increment": "./increment-build.sh",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "auth-test": "node test-auth.js",
    "web": "webpack serve --mode development",
    "web:prod": "webpack serve --mode production",
    "build": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "build:web": "webpack --mode production",
    "prebuild:android": "cd android && ./gradlew clean",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.19.5",
    "@react-navigation/bottom-tabs": "^6.4.0",
    "@react-navigation/native": "^6.0.13",
    "@react-navigation/stack": "^6.3.2",
    "@tsconfig/react-native": "^3.0.8",
    "@types/react-native-vector-icons": "^6.4.18",
    "axios": "^1.6.0",
    "h3-js": "^4.1.0",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "0.72.6",
    "react-native-dotenv": "^3.4.11",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.18.1",
    "react-native-maps": "^1.7.1",
    "react-native-permissions": "^3.10.1",
    "react-native-push-notification": "^8.1.1",
    "react-native-safe-area-context": "^4.4.1",
    "react-native-screens": "^3.29.0",
    "react-native-svg": "^13.14.0",
    "react-native-vector-icons": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.80.2",
    "@react-native/metro-config": "^0.72.11",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "babel-loader": "^10.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "html-webpack-plugin": "^5.6.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "metro-cache-key": "^0.82.5",
    "metro-file-map": "^0.76.8",
    "metro-react-native-babel-preset": "^0.76.8",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.8.0",
    "react-native-web": "^0.19.13",
    "react-native-web-maps": "^0.3.0",
    "typescript": "^5.9.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}

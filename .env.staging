# Staging environment variables
ENV=staging

# API Configuration
API_BASE_URL=https://staging-api.forseti.life/api
API_TIMEOUT=15000

# Feature Flags
ENABLE_DEBUG_MODE=true
ENABLE_MOCK_DATA=false
ENABLE_ANALYTICS=true

# Map Configuration
GOOGLE_MAPS_API_KEY=your_staging_google_maps_api_key_here
DEFAULT_LATITUDE=37.7749
DEFAULT_LONGITUDE=-122.4194

# Auth Configuration
AUTH_DOMAIN=staging-auth.forseti.life
AUTH_CLIENT_ID=staging_client_id

# Other Settings
LOG_LEVEL=info
